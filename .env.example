# API Keys
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
CASETEXT_API_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Multi-tenancy (Wolf Law = Tenant 1)
WOLF_LAW_PHONE_NUMBER=
WOLF_LAW_ELEVENLABS_AGENT_ID=

# Access Control (Mode 1 — Executive Assistant)
APPROVED_NUMBER_ISAIAH=
APPROVED_NUMBER_SCOTT=

# Outbound message safety (Redis-backed; prevents iMessage storms)
# JUSTICE_OUTBOUND_PAUSE — set to "true" to instantly mute ALL automated iMessages (kill-switch).
JUSTICE_OUTBOUND_PAUSE=
# JUSTICE_OUTBOUND_DAILY_MAX — hard cap on automated iMessages per day (default 20).
JUSTICE_OUTBOUND_DAILY_MAX=20
# JUSTICE_CALENDAR_MAX_DAYS_OUT — block scheduling events further out than this without
#   explicit confirm (default 120). Guards against mis-dated (e.g. wrong-year) events.
JUSTICE_CALENDAR_MAX_DAYS_OUT=120
# JUSTICE_AUTONOMOUS_BATCH_ENABLED — deprecated autonomous-batch pipeline; leave unset/false.
JUSTICE_AUTONOMOUS_BATCH_ENABLED=

# Database
DATABASE_URL=
REDIS_URL=

# Attorney Portal
PORTAL_BASE_URL=https://wronged.ai/attorney-portal
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Demo Portal (localhost only)
DEMO_PORTAL_PASSWORD=
DEMO_PORTAL_PORT=3001

# Executive Webhook
EXECUTIVE_WEBHOOK_PORT=3002
WEBHOOK_BASE_URL=

# Calendar + Email (Executive Assistant)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GMAIL_USER=justice@wolflaw.ai
GMAIL_APP_PASSWORD=

# Job Discovery (Doppler)
# JUSTICE_JOBS_DB_ID — Notion database id for discovered jobs (Isaiah provisions).
#   Required props: company (Title), role (Text), link (URL), source (Select),
#   ATS (Select), fit_score (Number), lane (Select), contract/FT (Select),
#   stack (Text), location (Text), date_found (Date),
#   status (Status: new|reviewing|applied|passed), why_it_fits (Text)
JUSTICE_JOBS_DB_ID=
# SERPAPI_KEY — SerpAPI key for the Google Jobs path (Workday enterprises).
SERPAPI_KEY=
# JOB_DIGEST_TOP_N — number of roles in the daily 8:30am CT digest (default 5).
JOB_DIGEST_TOP_N=5
# RESUME_MASTER_YAML — absolute path to resume_data.yaml (optional; falls back to repo copy).
RESUME_MASTER_YAML=
