{
  "name": "justice-repo",
  "version": "1.0.0",
  "private": true,
  "description": "Justice Platform — Wronged.ai SaaS + attorney marketplace",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev:attorney-portal": "pnpm --filter attorney-portal dev",
    "dev:demo-portal": "pnpm --filter demo-portal dev",
    "dev:agent": "pnpm --filter @justice/justice-agent dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.9"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  }
}